{
  "name": "compass-plugin-bilibili",
  "version": "0.2.3",
  "description": "Standalone Bilibili data source plugin for Compass Music",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "@types/node": "^24.5.2"
  },
  "compass": {
    "id": "com.compass.bilibili",
    "name": "Bilibili 音乐",
    "version": "0.2.3",
    "description": "搜索和播放 Bilibili 上的音乐视频",
    "author": "Compass Music Team",
    "platforms": [
      "all"
    ],
    "main": "dist/index.js",
    "brandColor": "#d33682",
    "capabilities": {
      "dataSource": true
    },
    "type": "plugin",
    "pluginType": "data-source"
  }
}
